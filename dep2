apiVersion: apps/v1
kind: Deployment
metadata:
  name: app-deployment2
spec:
  replicas: 2
  selector:
    matchLabels:
      app: vara
  template:
    metadata:
      labels:
        app: vara
    spec:
      containers:
      - name: vara
        image: varsha0411/mykubee:v1
        ports:
        - containerPort: 8080
---
apiVersion: v1
kind: Service
metadata:
  name: app-service2
spec:
  selector:
    app: vara
  ports:
  - port: 80
    targetPort: 8080
